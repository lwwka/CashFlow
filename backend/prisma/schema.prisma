generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../../docs/prisma-erd.svg"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String        @unique @db.VarChar(254)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  budgets      Budget[]
  categories   Category[]
  monthlyGoals MonthlyGoal[]
  transactions Transaction[]

  @@map("users")
}

model Category {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  name         String           @db.VarChar(64)
  type         transaction_type
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  budgets      Budget[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions Transaction[]

  @@unique([userId, name, type], map: "categories_user_name_type_uniq")
  @@map("categories")
}

model Transaction {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  categoryId String?          @map("category_id") @db.Uuid
  type       transaction_type
  amount     Decimal          @db.Decimal(12, 2)
  occurredOn DateTime         @map("occurred_on") @db.Date
  note       String?          @db.VarChar(500)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?        @map("deleted_at") @db.Timestamptz(6)
  category   Category?        @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("transactions")
}

model Budget {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  categoryId String?   @map("category_id") @db.Uuid
  month      String    @db.Char(7)
  amount     Decimal   @db.Decimal(12, 2)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, month, categoryId], map: "budgets_user_month_category_uniq")
  @@index([userId, month], map: "idx_budgets_user_month")
  @@map("budgets")
}

model MonthlyGoal {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  month         String   @db.Char(7)
  savingsTarget Decimal  @map("savings_target") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, month], map: "monthly_goals_user_month_uniq")
  @@index([userId, month], map: "idx_monthly_goals_user_month")
  @@map("monthly_goals")
}

enum transaction_type {
  income
  expense
}
